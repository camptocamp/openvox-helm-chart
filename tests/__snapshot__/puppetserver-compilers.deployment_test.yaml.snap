manifest should match snapshot:
  1: |
    apiVersion: apps/v1
    kind: Deployment
    metadata:
      labels:
        app.kubernetes.io/component: puppetserver-compilers
        app.kubernetes.io/instance: puppetserver
        app.kubernetes.io/managed-by: Helm
        app.kubernetes.io/name: puppetserver
        app.kubernetes.io/version: 8.14.0
        helm.sh/chart: puppetserver-10.1.1
      name: puppetserver-puppetserver-compiler
    spec:
      replicas: 1
      selector:
        matchLabels:
          app.kubernetes.io/component: puppetserver-compilers
          app.kubernetes.io/name: puppetserver
      strategy:
        type: RollingUpdate
      template:
        metadata:
          annotations:
            checksum/hiera-configmap: 01ba4719c80b6fe911b091a7c05124b64eeece964e09c058ef8f9805daca546b
            checksum/r10k-code.configmap: 01ba4719c80b6fe911b091a7c05124b64eeece964e09c058ef8f9805daca546b
            checksum/r10k-hiera.configmap: 01ba4719c80b6fe911b091a7c05124b64eeece964e09c058ef8f9805daca546b
          labels:
            app.kubernetes.io/component: puppetserver-compilers
            app.kubernetes.io/instance: puppetserver
            app.kubernetes.io/managed-by: Helm
            app.kubernetes.io/name: puppetserver
            app.kubernetes.io/version: 8.14.0
            helm.sh/chart: puppetserver-10.1.1
        spec:
          containers:
            - args:
                - exec /opt/puppetlabs/bin/puppetserver foreground
              command:
                - /bin/bash
                - -c
              env: null
              envFrom: null
              image: ghcr.io/openvoxproject/openvoxserver:8.14.0-main
              imagePullPolicy: IfNotPresent
              livenessProbe:
                failureThreshold: 3
                periodSeconds: 30
                successThreshold: 1
                tcpSocket:
                  port: 8140
                timeoutSeconds: 10
              name: puppetserver
              ports:
                - containerPort: 8140
              readinessProbe:
                failureThreshold: 3
                httpGet:
                  path: /status/v1/simple
                  port: 8140
                  scheme: HTTPS
                periodSeconds: 60
                successThreshold: 1
                timeoutSeconds: 20
              resources: {}
              securityContext:
                allowPrivilegeEscalation: false
                capabilities:
                  drop:
                    - all
                runAsGroup: 1001
                runAsNonRoot: true
                runAsUser: 1001
              startupProbe:
                failureThreshold: 30
                periodSeconds: 15
                tcpSocket:
                  port: 8140
              volumeMounts:
                - mountPath: /etc/puppetlabs/code/
                  name: puppet-code-storage
                - mountPath: /etc/puppetlabs/puppet/
                  name: puppet-puppet-storage
                - mountPath: /etc/puppetlabs/puppetserver/
                  name: puppet-puppetserver
          hostname: puppet
          imagePullSecrets: null
          securityContext:
            fsGroup: 1001
          volumes:
            - name: puppet-code-storage
              persistentVolumeClaim:
                claimName: puppetserver-code-claim
            - name: puppet-puppet-storage
              persistentVolumeClaim:
                claimName: puppetserver-puppet-claim
            - configMap:
                name: puppetserver-manifests-config
              name: manifests-volume
            - name: puppet-puppetserver
              persistentVolumeClaim:
                claimName: puppetserver-puppetserver-claim
